# Use 'git add -f' to force-add small, necessary data files
data/
*.csv
*.json
*.jsonl
*.parquet
*.npy
*.npz
*.sqlite
*.db

# Trained models and checkpoints
models/
checkpoints/
*.pth
*.pt
*.h5
*.onnx
*.pkl
*.joblib

